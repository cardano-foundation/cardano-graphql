    "data.stakePools[*].relays",
    "data.stakePools[*].metadataHash",
    "data.stakePools[*].url",
    "data.stakePools[*].fixedCost",
    "data.stakePools[*].margin",
    "data.stakePools[*].pledge",
    "data.stakePools[*].rewardAddress",
    "data.stakePools[*].owners"
  ],
  "network": "mainnet",
  "query_file": "queries/example/stake_pools/allStakePoolFields.graphql",
